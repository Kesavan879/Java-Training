class Solution {
    public char findTheDifference(String s, String t) {
        int freq[] = new int[26];
        int m = t.length();

        for(int i=0; i<m; i++)
        {
            freq[t.charAt(i) - 'a']++;

            if(i != m - 1)
            {
                freq[s.charAt(i) - 'a']--;
            }
        }

        char ans = ' ';
        for(int i=0; i<26; i++)
        {
            if(freq[i] != 0)
            {
                //here i used to get ascii
                ans = (char) (i + 'a');
            }
        }

        return ans;
    }
}
