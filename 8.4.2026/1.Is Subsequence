class Solution {
    public boolean isSubsequence(String s, String t) {
        int i=0,j=0;
        while(i<s.length() && j<t.length()){
            if(s.charAt(i)==t.charAt(j)) i++; //Increment while the characters are equal
            j++;
        }
        if(i==s.length()){ //Check whether the lengths are equal
            return true;
        }
        return false;
    }
}
