import java.util.*;
class Main1 {
    public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      int a=sc.nextInt();
      if (a<=1){
          System.out.println("Not prime");
         
      }
      boolean isprime=true;
      for(int i=2;i<a;i++){
          if(a%i==0){
              isprime=false;
              break;
          }
      }
      if(isprime){
          System.out.println("it is prime number");
      }
      else{
          System.out.println("it is not a prime number");
      }
    }
}
